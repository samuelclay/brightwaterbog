# Copy to tools/eufy-security.local.env and keep the real values out of git.
USERNAME=replace-with-eufy-account-email
PASSWORD=replace-with-eufy-account-password
COUNTRY=US
LANGUAGE=en
TRUSTED_DEVICE_NAME=Brightwater Camera Monitor
P2P_CONNECTION_SETUP=2
POLLING_INTERVAL_MINUTES=30
PORT=3000
# Optional local discovery hint: STATION_SERIAL:IP;STATION_SERIAL:IP
STATION_IP_ADDRESSES=
