# Copy to tools/camera_monitor.docker.local.env on the Docker host.
# Keep all real values out of git.
CAMERA_NEST_CLIENT_ID=replace-with-google-oauth-client-id
CAMERA_NEST_CLIENT_SECRET=replace-with-google-oauth-client-secret
CAMERA_NEST_REFRESH_TOKEN=replace-with-google-oauth-refresh-token
CAMERA_NEST_PROJECT_ID=replace-with-device-access-project-id

# LAN address and mapped media port of this Docker host. WebRTC browsers use
# this encrypted media path after signaling through cameras.local.
CAMERA_MONITOR_WEBRTC_CANDIDATE=192.168.1.10:8555

# Eufy grid view captures short-lived thumbnails with bounded P2P concurrency.
# Fullscreen always becomes one exclusive continuous stream.
CAMERA_MONITOR_EUFY_VIEWER_SLOTS=2
CAMERA_MONITOR_EUFY_THUMBNAIL_REFRESH_SECONDS=20

# Resident Nest warming is deliberately disabled by default. When enabled, Nest
# background streaming stops after 48 hours without a viewer. Eufy never warms
# without a visible browser.
CAMERA_MONITOR_WARM_AGENT_ENABLED=0
CAMERA_MONITOR_WARM_IDLE_HOURS=48
