# Copy to tools/camera_monitor.docker.local.env on the Docker host.
# Keep the real token and local address out of git.
CAMERA_MONITOR_HA_URL=http://192.0.2.10:8123
CABIN_HOME_ASSISTANT_TOKEN=replace-with-a-long-lived-home-assistant-token

# Resident warming is deliberately disabled by default. A viewer can still
# start cameras on demand without keeping Home Assistant streams hot all day.
CAMERA_MONITOR_WARM_AGENT_ENABLED=0
