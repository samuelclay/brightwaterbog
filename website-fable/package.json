{
  "name": "brightwater-bog-site",
  "type": "module",
  "private": true,
  "scripts": {
    "catalog": "node scripts/catalog.mjs",
    "dev:img": "node scripts/dev-image-server.mjs",
    "dev:astro": "astro dev",
    "dev": "npm run catalog && concurrently -k -n img,astro -c magenta,cyan \"npm:dev:img\" \"npm:dev:astro\"",
    "build": "npm run catalog && astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.5",
    "@fontsource-variable/newsreader": "^5.2.5",
    "@fontsource/ibm-plex-mono": "^5.2.5",
    "astro": "^5.6.1",
    "gray-matter": "^4.0.3",
    "sharp": "^0.34.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
