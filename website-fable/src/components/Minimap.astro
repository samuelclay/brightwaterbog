---
import trail from "../data/trail.json";

const nodes = trail.nodes as Array<{
  slug: string;
  title: string;
  kicker: string | null;
  glass: string;
  order: number;
  status: string;
  count: number;
  x: number;
  y: number;
}>;

const base = trail.loopD as string; // full loop (closes 20 → 1)
const prog = trail.pathD as string; // open path — progress fills along this
const first = nodes[0];
---

<aside class="map-rail">
  <div class="minimap" data-minimap>
    <p class="minimap__title-line">Counterclockwise trail</p>
    <div class="minimap__caption minimap__caption--top">
      <span class="minimap__now" data-now>{first.title}</span>
      <span class="minimap__count"><b data-current-number>1</b> of {nodes.length}</span>
    </div>

    <div class="minimap__frame">
      <svg viewBox={trail.viewBox} role="group" aria-label="Map of the sculpture trail">
        <path class="mm-path mm-path--shadow" d={base} />
        <path class="mm-path mm-path--base" d={base} />
        <path class="mm-path mm-path--lit" d={prog} pathLength="1" data-lit />
        {
          nodes.map((n, i) => (
            <a
              class="mm-marker"
              data-node={n.slug}
              href={`#stop-${n.slug}`}
              aria-label={`Go to ${n.title}`}
              style={`--marker-color: var(--${n.glass})`}
            >
              <circle class="mm-halo" cx={n.x} cy={n.y} r="5.6" />
              <circle class="mm-dot" cx={n.x} cy={n.y} r="2.9" />
              <text x={n.x} y={n.y + 0.95}>{i + 1}</text>
            </a>
          ))
        }
      </svg>
    </div>
    <p class="minimap__hint">Choose a marker to jump to a sculpture.</p>
  </div>
</aside>
