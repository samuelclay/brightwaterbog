---
import { imageUrl, srcset, FULL_WIDTHS } from "../lib/imageUrl";
import photosData from "../data/photos.json";

// Big full-bleed hero: the most recent photo of Stargate (the trail's entrance).
const photos = photosData as Record<string, Array<{ key: string; era: string; width: number | null; height: number | null }>>;
const stargate = photos["stargate"] ?? [];
const nows = stargate.filter((p) => p.era === "now");
const hero = nows.at(-1) ?? stargate[0];
---

<section class="hero">
  {
    hero && (
      <img
        class="hero__media"
        src={imageUrl(hero.key, { w: 2200, fit: "cover" })}
        srcset={srcset(hero.key, FULL_WIDTHS, "cover")}
        sizes="100vw"
        width={hero.width ?? undefined}
        height={hero.height ?? undefined}
        alt="Stargate at Bright Water Bog"
        fetchpriority="high"
        decoding="async"
      />
    )
  }
  <div class="hero__veil" aria-hidden="true"></div>

  <div class="hero__inner">
    <h1 class="hero__title">Bright Water <em>Bog</em></h1>
  </div>

  <div class="hero__foot">
    <span class="scroll-cue"><span class="scroll-cue__dot"></span> Scroll to begin</span>
  </div>
</section>
